# ===========================================================================
# Copilot Studio Streaming Playground - server configuration
# Copy this file to ".env" and fill in ONE connection option.
# ===========================================================================

# Port the playground server listens on.
PORT=3978

# --- Option 1 (recommended): Copilot Studio token endpoint -----------------
# In Copilot Studio: Settings > Channels > "Custom website" (or Mobile app),
# copy the "Token endpoint" URL. The server fetches a short-lived token from it
# so the browser never holds a secret.
# COPILOT_TOKEN_ENDPOINT=https://<env-id>.environment.api.powerplatform.com/powervirtualagents/botsbyschema/<schema-name>/directline/token?api-version=2022-03-01-preview

# --- Option 2: Direct Line channel secret ----------------------------------
# If you wired the agent to an Azure Bot "Direct Line" channel, paste a secret.
# The server exchanges it for a token at runtime.
# DIRECT_LINE_SECRET=your-direct-line-secret

# Override only if you use a regional/sovereign Direct Line endpoint.
# DIRECT_LINE_TOKEN_GENERATE_URL=https://directline.botframework.com/v3/directline/tokens/generate

# --- Option 3: Copilot Studio SDK (Direct-to-Engine) -----------------------
# This is the ONLY connection mode that emits generative (token-by-token)
# streaming chunks. The signed-in user authenticates via Entra ID (MSAL) in the
# browser; no server secret is involved. Values below are NOT secrets - they are
# sent to the browser to pre-fill the "Copilot Studio SDK" mode.
#
# Create an Entra ID app registration (SPA platform) with redirect URI
# http://localhost:3978, and the delegated API permission
# "CopilotStudio.Copilots.Invoke" (API: Power Platform API).
#
# ENTRA_CLIENT_ID      = Application (client) ID of the SPA app registration.
# ENTRA_TENANT_ID      = Directory (tenant) ID (must match the agent's tenant).
# COPILOT_ENVIRONMENT_ID = Copilot Studio: Settings > Advanced > Metadata > Environment Id.
# COPILOT_SCHEMA_NAME    = Copilot Studio: Settings > Advanced > Metadata > Schema name.
# COPILOT_AGENT_CLOUD    = Prod (default) | Gov | High | DoD | Mooncake.
# ENTRA_CLIENT_ID=
# ENTRA_TENANT_ID=
# COPILOT_ENVIRONMENT_ID=
# COPILOT_SCHEMA_NAME=mjsrc_agent
# COPILOT_AGENT_CLOUD=Prod
